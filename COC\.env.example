# COC API Key (from https://developer.clashofclans.com)
COC_API_KEY=your_api_key_here

# Proxy server port
PROXY_PORT=3001

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coc_db
DB_USER=coc_user
DB_PASSWORD=your_password

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
